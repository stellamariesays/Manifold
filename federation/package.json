{
  "name": "manifold-federation",
  "version": "0.1.0",
  "description": "Federated mesh topology for Manifold agents across multiple machines",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npx tsx examples/two-server-demo.ts",
    "clean": "find . -name 'dist' -type d -not -path '*/node_modules/*' | xargs rm -rf"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.6",
    "@types/ws": "^8.5.13",
    "jsdom": "^29.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.1.3",
    "@noble/ed25519": "^2.3.0",
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  }
}
